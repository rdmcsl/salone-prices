# SalonePrices – Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Africa's Talking (get from africastalking.com)
AT_API_KEY=your_africas_talking_api_key_here
AT_USERNAME=your_at_username_here
AT_SENDER_ID=SalonePrices
AT_USSD_CODE=*384*4321#

# Orange Money Sierra Leone (get from developer.orange.com)
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_MERCHANT_KEY=your_orange_merchant_key
ORANGE_NOTIF_URL=https://yourdomain.com/webhooks/orange-money

# Google Sheets (service account JSON file path)
GOOGLE_CREDS_JSON=google_credentials.json
PRICES_SHEET_ID=your_google_sheet_id_from_url
SUBSCRIBERS_SHEET_ID=your_subscribers_sheet_id

# Optional: override defaults
# SMS_SEND_HOUR=7
# FREE_TRIAL_WEEKS=4
